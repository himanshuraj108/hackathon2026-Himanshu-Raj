# Required
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Backup LLM (optional but recommended)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Database (optional — agent runs without it, audit log saved to audit_log.json)
MONGODB_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/shopwave_agent

# Server
PORT=4000
FRONTEND_URL=http://localhost:5173

# Agent Configuration
MAX_CONCURRENCY=5
LOG_LEVEL=info
